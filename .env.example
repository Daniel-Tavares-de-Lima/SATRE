# SATRE — template de variáveis de ambiente (SEGURO para commitar no GitHub)
#
# Setup local:
#   copy .env.example .env
#   copy .env apps\api\.env
#
# O arquivo .env NUNCA vai pro Git — nele você coloca segredos reais (produção).
# Em dev local, os valores abaixo funcionam com o docker-compose.yml.

# PostgreSQL (docker-compose usa user/senha/db: satre/satre/satre)
DATABASE_URL=postgresql://satre:satre@localhost:5432/satre

# Gere strings únicas em produção (openssl rand -base64 32)
JWT_SECRET=substitua-por-segredo-jwt-minimo-32-caracteres
JWT_REFRESH_SECRET=substitua-por-segredo-refresh-com-minimo-32-chars

PORT=3000

# Salt para hash anônimo de device nos reports
DEVICE_HASH_SALT=substitua-por-salt-unico
