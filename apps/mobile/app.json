{
  "expo": {
    "name": "SATRE",
    "slug": "satre",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "satre",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#38A19A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.satre.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#38A19A"
      },
      "package": "com.satre.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "O SATRE usa sua localização para mostrar unidades de saúde próximas."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
